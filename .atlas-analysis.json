  "publicApiSurface": [
    "POST /api/chat - AI assistant chat endpoint",
    "POST /api/compile - LaTeX compilation endpoint",
    "POST /api/liveblocks-auth - Real-time collaboration authentication",
    "createProject() - Server action to create new project",
    "deleteProject(projectId) - Server action to delete project",
    "renameProject(projectId, newTitle) - Server action to rename project",
    "inviteToProject(projectId, email) - Server action to invite collaborators",
    "removeFromProject(projectId, email) - Server action to remove collaborators",
    "leaveProject(projectId) - Server action to leave shared project"
